---
import Base from '../layouts/Base.astro'
---

<Base title="Not found · TimeShift" description="This page is not on the timeline.">
  <main id="main" tabindex="-1" class="mx-auto flex min-h-screen max-w-[600px] flex-col items-center justify-center px-5 text-center">
    <p class="font-sans text-[11px] uppercase tracking-[0.22em] text-kicker mb-5">Lost in time</p>
    <h1 class="font-display font-light text-6xl text-ink mb-4">404</h1>
    <p class="font-display font-medium text-xl text-ink mb-3">This moment is not on the timeline</p>
    <p class="font-sans text-[15px] leading-relaxed text-muted max-w-sm mb-9">
      The page you were looking for does not exist. The trail, however, runs all the
      way from 1879 to 2038.
    </p>
    <a href="/" class="font-sans text-sm font-medium text-link">Back to the timeline &#8594;</a>
  </main>
</Base>
