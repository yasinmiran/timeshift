---
interface Props {
  count: number
}

const { count } = Astro.props
---

<header class="text-center pt-20 pb-6">
  <p class="font-sans text-[11px] uppercase tracking-[0.22em] text-kicker mb-5">
    A history for people who build with time
  </p>
  <h1 class="font-display font-light text-6xl text-ink mb-5">TimeShift</h1>
  <p class="font-sans text-[16px] leading-relaxed text-muted max-w-sm mx-auto">
    {count} time changes worth knowing, from 1582 to the bugs still ahead,
    gathered into one long walk. Scroll to begin.
  </p>
  <div class="mt-9 text-accent text-lg" aria-hidden="true">&#8595;</div>
</header>
