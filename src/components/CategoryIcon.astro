---
import { ICONS } from '../lib/icons'
import type { CategoryId } from '../lib/categories'

interface Props {
  category: CategoryId
  color: string
  dim?: boolean
}

const { category, color, dim = false } = Astro.props
---

<span
  class:list={[
    'relative z-10 mx-auto mb-4 flex h-8 w-8 items-center justify-center rounded-full bg-paper',
    dim && 'opacity-40',
  ]}
  style={`color:${color}`}
  aria-hidden="true"
>
  <svg
    width="22"
    height="22"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.6"
    stroke-linecap="round"
    stroke-linejoin="round"
    set:html={ICONS[category]}
  ></svg>
</span>
