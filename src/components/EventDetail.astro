---
import type { Stop } from '../lib/events'

interface Props {
  stop: Stop
}

const { stop } = Astro.props
---

{/* The "read further" layer: when, who decided, developer notes, and citations.
    The headline, category, date, and story already sit inline in the card. */}
<div class="ev-extra-inner">
  <dl class="flex flex-col gap-2 mb-3.5">
    <div class="flex justify-between gap-3 font-sans text-[13px]">
      <dt class="text-muted">When</dt>
      <dd class="text-ink font-medium text-right">{stop.facts.when}</dd>
    </div>
    <div class="flex justify-between gap-3 font-sans text-[13px]">
      <dt class="text-muted">Who decided</dt>
      <dd class="text-ink font-medium text-right">{stop.facts.who}</dd>
    </div>
    {stop.facts.tzRelease && (
      <div class="flex justify-between gap-3 font-sans text-[13px]">
        <dt class="text-muted">IANA tz release</dt>
        <dd class="text-ink font-medium text-right">{stop.facts.tzRelease}</dd>
      </div>
    )}
  </dl>

  {stop.devNote && (
    <p class="font-sans text-[13px] leading-relaxed text-devnote bg-panel rounded-lg p-3 mb-3.5">
      <span class="font-semibold text-devnote-strong">For developers: </span>{stop.devNote}
    </p>
  )}

  <a
    class="font-sans text-[13px] font-medium text-link"
    href={stop.source.url}
    target="_blank"
    rel="noopener noreferrer"
  >
    {stop.source.title} <span aria-hidden="true">&#8599;</span><span class="sr-only"> (opens in a new tab)</span>
  </a>

  {stop.sidenotes.length > 0 && (
    <div class="mt-3.5 pt-3 border-t border-hairline">
      <p class="font-sans text-[11px] uppercase tracking-[0.14em] text-muted mb-2">See also</p>
      <ul class="flex flex-col gap-1.5">
        {stop.sidenotes.map((s) => (
          <li>
            <a
              class="font-sans text-[12.5px] leading-snug text-link"
              href={s.url}
              target="_blank"
              rel="noopener noreferrer"
            >
              {s.label} <span aria-hidden="true">&#8599;</span><span class="sr-only"> (opens in a new tab)</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  )}

  {stop.academicRefs.length > 0 && (
    <div class="mt-3.5 pt-3 border-t border-hairline">
      <p class="font-sans text-[11px] uppercase tracking-[0.14em] text-muted mb-2">Papers</p>
      <ul class="flex flex-col gap-2">
        {stop.academicRefs.map((r) => (
          <li class="font-sans text-[12.5px] leading-snug">
            <a class="text-link" href={r.url} target="_blank" rel="noopener noreferrer">
              {r.title} <span aria-hidden="true">&#8599;</span><span class="sr-only"> (opens in a new tab)</span>
            </a>
            <span class="block text-muted">{r.authors} ({r.year}), {r.venue}</span>
          </li>
        ))}
      </ul>
    </div>
  )}
</div>
